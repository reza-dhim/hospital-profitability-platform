// Sprint 1 scope: Tenancy + Identity entity groups only, per docs/02_DOMAIN_MODEL.md §1
// and docs/ARCHITECT_AUDIT.md Sprint 1 ("Postgres schema v1 migration"). Sprint 3 adds
// the Master Data entity group + hospital_settings (Configuration group) below. All
// remaining entity groups (Transactional, Upload Pipeline, Calculation, AI, Reporting,
// Platform/audit_logs) are added in the sprint that owns them — see
// docs/00_DOCUMENTATION_INDEX.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Tenancy (docs/03_MULTI_TENANT.md §1) ---------------------------------

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  hospitals Hospital[]
  users     User[]

  @@map("organizations")
}

model Hospital {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  name            String
  code            String
  address         String?
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization Organization             @relation(fields: [organizationId], references: [id])
  branches     Branch[]
  roles        Role[]
  users        User[]
  memberships  UserHospitalMembership[]
  createdBy    User?                    @relation("HospitalCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy    User?                    @relation("HospitalUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  // --- Sprint 3 master data (docs/02_DOMAIN_MODEL.md §1) ---
  costCenters       CostCenter[]
  profitCenters     ProfitCenter[]
  drivers           Driver[]
  allocationRules   AllocationRule[]
  coaAccounts       CoaAccount[]
  doctors           Doctor[]
  services          Service[]
  employees         Employee[]
  assets            Asset[]
  vendors           Vendor[]
  bmhpItems         BmhpItem[]
  tariffs           Tariff[]
  hospitalSettings  HospitalSettings?
  periods           Period[]
  uploadBatches     UploadBatch[]
  costEntries       CostEntry[]
  revenueEntries    RevenueEntry[]
  driverValues      DriverValue[]
  medicalActivities MedicalActivity[]
  allocationRuns    AllocationRun[]
  targetMargins     TargetMargin[]

  @@unique([organizationId, code])
  @@map("hospitals")
}

model Branch {
  id              String    @id @default(uuid())
  hospitalId      String    @map("hospital_id")
  name            String
  code            String
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  hospital  Hospital @relation(fields: [hospitalId], references: [id])
  createdBy User?    @relation("BranchCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("BranchUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@map("branches")
}

// --- Identity (docs/04_RBAC.md, docs/05_AUTHENTICATION.md) ----------------

enum UserStatus {
  active
  suspended
  invited

  @@map("user_status")
}

model User {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  // Single hospital + single role for Sprint 1. The full multi-hospital
  // membership model (user_hospital_memberships, docs/04_RBAC.md §4) is
  // Sprint 2 scope, built when RBAC enforcement itself is implemented.
  hospitalId     String?    @map("hospital_id")
  roleId         String?    @map("role_id")
  name           String
  email          String     @unique
  passwordHash   String     @map("password_hash")
  status         UserStatus @default(active)
  // Reserved per docs/05_AUTHENTICATION.md §3 — MFA is a fast-follow, not an
  // MVP blocker, but the login flow needs a branch point to exist from the
  // start. No TOTP logic is implemented in Sprint 2.1.
  mfaEnabled     Boolean    @default(false) @map("mfa_enabled")
  mfaSecret      String?    @map("mfa_secret")

  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization  Organization             @relation(fields: [organizationId], references: [id])
  hospital      Hospital?                @relation(fields: [hospitalId], references: [id])
  role          Role?                    @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  memberships   UserHospitalMembership[] @relation("MembershipUser")

  createdBy User? @relation("UserCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User? @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  createdUsers User[] @relation("UserCreatedBy")
  updatedUsers User[] @relation("UserUpdatedBy")

  hospitalsCreated   Hospital[]               @relation("HospitalCreatedBy")
  hospitalsUpdated   Hospital[]               @relation("HospitalUpdatedBy")
  branchesCreated    Branch[]                 @relation("BranchCreatedBy")
  branchesUpdated    Branch[]                 @relation("BranchUpdatedBy")
  rolesCreated       Role[]                   @relation("RoleCreatedBy")
  rolesUpdated       Role[]                   @relation("RoleUpdatedBy")
  membershipsCreated UserHospitalMembership[] @relation("MembershipCreatedBy")
  membershipsUpdated UserHospitalMembership[] @relation("MembershipUpdatedBy")

  // --- Sprint 3 master data ownership back-relations (created_by/updated_by) ---
  costCentersCreated      CostCenter[]       @relation("CostCenterCreatedBy")
  costCentersUpdated      CostCenter[]       @relation("CostCenterUpdatedBy")
  profitCentersCreated    ProfitCenter[]     @relation("ProfitCenterCreatedBy")
  profitCentersUpdated    ProfitCenter[]     @relation("ProfitCenterUpdatedBy")
  driversCreated          Driver[]           @relation("DriverCreatedBy")
  driversUpdated          Driver[]           @relation("DriverUpdatedBy")
  allocationRulesCreated  AllocationRule[]   @relation("AllocationRuleCreatedBy")
  allocationRulesUpdated  AllocationRule[]   @relation("AllocationRuleUpdatedBy")
  coaAccountsCreated      CoaAccount[]       @relation("CoaAccountCreatedBy")
  coaAccountsUpdated      CoaAccount[]       @relation("CoaAccountUpdatedBy")
  doctorsCreated          Doctor[]           @relation("DoctorCreatedBy")
  doctorsUpdated          Doctor[]           @relation("DoctorUpdatedBy")
  servicesCreated         Service[]          @relation("ServiceCreatedBy")
  servicesUpdated         Service[]          @relation("ServiceUpdatedBy")
  employeesCreated        Employee[]         @relation("EmployeeCreatedBy")
  employeesUpdated        Employee[]         @relation("EmployeeUpdatedBy")
  assetsCreated           Asset[]            @relation("AssetCreatedBy")
  assetsUpdated           Asset[]            @relation("AssetUpdatedBy")
  vendorsCreated          Vendor[]           @relation("VendorCreatedBy")
  vendorsUpdated          Vendor[]           @relation("VendorUpdatedBy")
  bmhpItemsCreated        BmhpItem[]         @relation("BmhpItemCreatedBy")
  bmhpItemsUpdated        BmhpItem[]         @relation("BmhpItemUpdatedBy")
  tariffsCreated          Tariff[]           @relation("TariffCreatedBy")
  tariffsUpdated          Tariff[]           @relation("TariffUpdatedBy")
  tariffsApproved         Tariff[]           @relation("TariffApprovedBy")
  hospitalSettingsCreated HospitalSettings[] @relation("HospitalSettingsCreatedBy")
  hospitalSettingsUpdated HospitalSettings[] @relation("HospitalSettingsUpdatedBy")
  periodsCreated          Period[]           @relation("PeriodCreatedBy")
  periodsUpdated          Period[]           @relation("PeriodUpdatedBy")
  uploadBatchesUploaded   UploadBatch[]      @relation("UploadBatchUploadedBy")
  allocationRunsCreated   AllocationRun[]    @relation("AllocationRunCreatedBy")
  targetMarginsSet        TargetMargin[]     @relation("TargetMarginSetBy")

  auditLogs AuditLog[]

  @@map("users")
}

/// The six default roles (docs/04_RBAC.md §2) are seeded per hospital.
/// Permission assignment (role_permissions rows) is populated in Sprint 2 —
/// this sprint only creates the roles themselves with empty permission sets.
model Role {
  id          String  @id @default(uuid())
  hospitalId  String  @map("hospital_id")
  name        String
  description String?
  isDefault   Boolean @default(false) @map("is_default")

  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  hospital        Hospital                 @relation(fields: [hospitalId], references: [id])
  users           User[]
  rolePermissions RolePermission[]
  memberships     UserHospitalMembership[]
  createdBy       User?                    @relation("RoleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?                    @relation("RoleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, name])
  @@map("roles")
}

/// Platform-wide permission catalog, `{module}.{action}` per docs/04_RBAC.md §3.
/// Populated in Sprint 2 alongside real endpoints; empty in Sprint 1.
model Permission {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// Per-hospital role assignment for a user, docs/04_RBAC.md §4 and
/// docs/03_MULTI_TENANT.md §4. Additive to `User.hospitalId`/`roleId` (the
/// Sprint 1 single-hospital simplification, still the source of the JWT's
/// `active_hospital_id`/`role` claims as of Sprint 2.2) — this table is the
/// authorization source for accessing a *non-active* hospital (e.g. via the
/// `X-Hospital-Id` header) and for group-level users who hold more than one
/// hospital membership. Login/token issuance is not yet membership-aware;
/// see docs/SPRINT_2_2_REVIEW.md "Known Limitations".
model UserHospitalMembership {
  id           String  @id @default(uuid())
  userId       String  @map("user_id")
  hospitalId   String  @map("hospital_id")
  roleId       String  @map("role_id")
  /// Row-level scope for `kepala_unit` (docs/04_RBAC.md §2 footnote) — will FK
  /// to `cost_centers`/`profit_centers` once Sprint 3 adds those tables; a
  /// bare id column until then so this table doesn't block on Sprint 3.
  scopedUnitId String? @map("scoped_unit_id")

  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  user      User     @relation("MembershipUser", fields: [userId], references: [id])
  hospital  Hospital @relation(fields: [hospitalId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])
  createdBy User?    @relation("MembershipCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("MembershipUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, hospitalId])
  @@map("user_hospital_memberships")
}

/// Rotating refresh tokens, docs/05_AUTHENTICATION.md §1, §6. "Session" in
/// user-facing terms — implemented in Sprint 2.1.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

// --- Master Data (docs/02_DOMAIN_MODEL.md §1-2, Sprint 3) -----------------
//
// Every model below is hospital-scoped via a direct `hospitalId` column —
// including `AllocationRule` and `CoaAccount`, which `02_DOMAIN_MODEL.md`'s
// relationship summary doesn't explicitly list under "hospitals 1─*", and
// `CoaAccount` which `DATABASE_SCHEMA.md` doesn't give any tenant column at
// all. A direct column (rather than scoping `AllocationRule` only through its
// `costCenter` relation, or leaving `CoaAccount` unscoped) is required so the
// generic CRUD engine (`common/crud`) can apply one uniform
// `where: { hospitalId }` tenant filter across every entity — the
// alternative (some entities scoped directly, others only via a join) would
// break that genericity and, for `CoaAccount`, would leave it failing the
// tenant-isolation acceptance criterion (`22_ACCEPTANCE_CRITERIA.md` §8).
//
// Cross-cutting columns (`deleted_at`, `created_by_user_id`,
// `updated_by_user_id`, `created_at`, `updated_at`) follow
// `02_DOMAIN_MODEL.md` §3, applied to every master-data *and configuration*
// table — `HospitalSettings` (Configuration group) gets the same columns.

enum MasterDataStatus {
  active
  inactive

  @@map("master_data_status")
}

enum TariffStatus {
  active
  superseded

  @@map("tariff_status")
}

enum AllocationMethod {
  direct
  step_down

  @@map("allocation_method")
}

/// Sprint 6 sub-task 0 (docs/09_PROFITABILITY_ENGINE.md §2): distinguishes
/// cost centers whose cost only ever flows out through the allocation graph
/// (`indirect`, e.g. HRD, IT) from ones directly incurred by a profit center
/// itself (`direct`, e.g. a lab's own reagent cost) and summed straight into
/// that profit center's `direct_cost` instead. Was an unvalidated free
/// string through Sprint 3/5 (all existing seed data used `"support"`,
/// migrated to `indirect`) — tightened here the same way
/// `AllocationRule.method` was in Sprint 5.
enum CostCenterType {
  direct
  indirect

  @@map("cost_center_type")
}

/// Period lifecycle, docs/25_PERIOD_CLOSING.md §1: draft -> open -> locked ->
/// closed, with a reopen action (locked|closed -> open) gated separately
/// (`period_closing.reopen`, System Admin only) from generate/open/lock/close
/// (`period_closing.write`, System Admin and CFO/Finance Director).
enum PeriodStatus {
  draft
  open
  locked
  closed

  @@map("period_status")
}

model CostCenter {
  id              String           @id @default(uuid())
  hospitalId      String           @map("hospital_id")
  code            String
  name            String
  type            CostCenterType
  /// Set exactly when `type = direct` (DB `CHECK`, mirroring the
  /// driver_values/allocated_costs polymorphic-target pattern) — a direct
  /// cost center is inherently "owned" by exactly one profit center,
  /// configured once at master-data time rather than tagged per
  /// `cost_entries` row (docs/09_PROFITABILITY_ENGINE.md §2).
  profitCenterId  String?          @map("profit_center_id")
  status          MasterDataStatus @default(active)
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  hospital               Hospital         @relation(fields: [hospitalId], references: [id])
  profitCenter           ProfitCenter?    @relation(fields: [profitCenterId], references: [id])
  allocationRules        AllocationRule[]
  employees              Employee[]
  assets                 Asset[]
  costEntries            CostEntry[]
  driverValuesAsTarget   DriverValue[]
  allocatedCostsAsSource AllocatedCost[]  @relation("AllocatedCostSource")
  allocatedCostsAsTarget AllocatedCost[]  @relation("AllocatedCostTarget")
  createdBy              User?            @relation("CostCenterCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy              User?            @relation("CostCenterUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@map("cost_centers")
}

model ProfitCenter {
  id              String           @id @default(uuid())
  hospitalId      String           @map("hospital_id")
  code            String
  name            String
  department      String?
  status          MasterDataStatus @default(active)
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  hospital             Hospital              @relation(fields: [hospitalId], references: [id])
  services             Service[]
  revenueEntries       RevenueEntry[]
  directCostCenters    CostCenter[]
  driverValuesAsTarget DriverValue[]
  allocatedCosts       AllocatedCost[]
  profitabilityResults ProfitabilityResult[]
  createdBy            User?                 @relation("ProfitCenterCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy            User?                 @relation("ProfitCenterUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@map("profit_centers")
}

model Driver {
  id              String    @id @default(uuid())
  hospitalId      String    @map("hospital_id")
  code            String
  name            String
  unit            String
  description     String?
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  hospital        Hospital         @relation(fields: [hospitalId], references: [id])
  allocationRules AllocationRule[]
  driverValues    DriverValue[]
  allocatedCosts  AllocatedCost[]
  createdBy       User?            @relation("DriverCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?            @relation("DriverUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@map("drivers")
}

/// docs/08_COST_ALLOCATION_ENGINE.md §2: links a cost center to the driver
/// used to spread its pool, `priority` orders step-down processing.
model AllocationRule {
  id              String           @id @default(uuid())
  hospitalId      String           @map("hospital_id")
  costCenterId    String           @map("cost_center_id")
  driverId        String           @map("driver_id")
  /// Was an unvalidated free string through Sprint 3 (comment there: "Free-
  /// form... label", deliberately left loose pending Sprint 5's real
  /// design). Tightened here to the same `AllocationMethod` enum
  /// `hospital_settings.allocation_method` already uses — a hospital may
  /// keep parallel rule sets tagged by method (docs/01_BUSINESS_RULES.md
  /// §2: a run's method selects which set applies), not just one.
  method          AllocationMethod
  priority        Int
  effectivePeriod String           @map("effective_period")
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  hospital   Hospital   @relation(fields: [hospitalId], references: [id])
  costCenter CostCenter @relation(fields: [costCenterId], references: [id])
  driver     Driver     @relation(fields: [driverId], references: [id])
  createdBy  User?      @relation("AllocationRuleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy  User?      @relation("AllocationRuleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([costCenterId, driverId, effectivePeriod])
  @@index([hospitalId])
  @@map("allocation_rules")
}

model CoaAccount {
  id              String    @id @default(uuid())
  hospitalId      String    @map("hospital_id")
  code            String
  name            String
  category        String
  createdByUserId String?   @map("created_by_user_id")
  updatedByUserId String?   @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  hospital    Hospital    @relation(fields: [hospitalId], references: [id])
  costEntries CostEntry[]
  createdBy   User?       @relation("CoaAccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy   User?       @relation("CoaAccountUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@map("coa_accounts")
}

model Doctor {
  id              String           @id @default(uuid())
  hospitalId      String           @map("hospital_id")
  code            String
  name            String
  specialty       String?
  status          MasterDataStatus @default(active)
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  hospital  Hospital @relation(fields: [hospitalId], references: [id])
  createdBy User?    @relation("DoctorCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("DoctorUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  medicalActivities          MedicalActivity[]
  doctorProfitabilityResults DoctorProfitabilityResult[]

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@map("doctors")
}

/// `currentTariff` denormalizes the active `Tariff` row's value for read
/// performance (docs/02_DOMAIN_MODEL.md `tariffs` note) — kept in sync by
/// `TariffService` whenever a new active tariff row is written.
model Service {
  id               String    @id @default(uuid())
  hospitalId       String    @map("hospital_id")
  profitCenterId   String    @map("profit_center_id")
  code             String
  name             String
  serviceType      String    @map("service_type")
  standardDuration Int?      @map("standard_duration")
  currentTariff    Decimal?  @map("current_tariff") @db.Decimal(14, 2)
  createdByUserId  String?   @map("created_by_user_id")
  updatedByUserId  String?   @map("updated_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  hospital                   Hospital                    @relation(fields: [hospitalId], references: [id])
  profitCenter               ProfitCenter                @relation(fields: [profitCenterId], references: [id])
  tariffs                    Tariff[]
  revenueEntries             RevenueEntry[]
  serviceUnitCosts           ServiceUnitCost[]
  medicalActivities          MedicalActivity[]
  doctorProfitabilityResults DoctorProfitabilityResult[]
  createdBy                  User?                       @relation("ServiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy                  User?                       @relation("ServiceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@index([profitCenterId])
  @@map("services")
}

model Employee {
  id                     String           @id @default(uuid())
  hospitalId             String           @map("hospital_id")
  code                   String
  name                   String
  roleTitle              String?          @map("role_title")
  departmentCostCenterId String?          @map("department_cost_center_id")
  employmentType         String           @map("employment_type")
  status                 MasterDataStatus @default(active)
  /// Set only when this row was created by a bulk upload (docs/06_UPLOAD_ENGINE.md) —
  /// null for rows entered directly via Master Data CRUD. Upload-created rows are
  /// insert-only (no upsert-by-code); rollback soft-deletes rows matching this batch.
  sourceFileId           String?          @map("source_file_id")
  createdByUserId        String?          @map("created_by_user_id")
  updatedByUserId        String?          @map("updated_by_user_id")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")
  deletedAt              DateTime?        @map("deleted_at")

  hospital             Hospital     @relation(fields: [hospitalId], references: [id])
  departmentCostCenter CostCenter?  @relation(fields: [departmentCostCenterId], references: [id])
  sourceFile           UploadBatch? @relation(fields: [sourceFileId], references: [id])
  createdBy            User?        @relation("EmployeeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy            User?        @relation("EmployeeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@index([sourceFileId])
  @@map("employees")
}

model Asset {
  id                 String           @id @default(uuid())
  hospitalId         String           @map("hospital_id")
  code               String
  name               String
  category           String
  costCenterId       String?          @map("cost_center_id")
  acquisitionCost    Decimal          @map("acquisition_cost") @db.Decimal(14, 2)
  depreciationMethod String           @map("depreciation_method")
  usefulLifeMonths   Int              @map("useful_life_months")
  status             MasterDataStatus @default(active)
  /// See `Employee.sourceFileId` doc comment — same semantics.
  sourceFileId       String?          @map("source_file_id")
  createdByUserId    String?          @map("created_by_user_id")
  updatedByUserId    String?          @map("updated_by_user_id")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")

  hospital   Hospital     @relation(fields: [hospitalId], references: [id])
  costCenter CostCenter?  @relation(fields: [costCenterId], references: [id])
  sourceFile UploadBatch? @relation(fields: [sourceFileId], references: [id])
  createdBy  User?        @relation("AssetCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy  User?        @relation("AssetUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@index([sourceFileId])
  @@map("assets")
}

model Vendor {
  id              String           @id @default(uuid())
  hospitalId      String           @map("hospital_id")
  code            String
  name            String
  category        String?
  status          MasterDataStatus @default(active)
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  hospital  Hospital   @relation(fields: [hospitalId], references: [id])
  bmhpItems BmhpItem[]
  createdBy User?      @relation("VendorCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?      @relation("VendorUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@map("vendors")
}

/// Bahan Medis Habis Pakai — consumable medical materials (docs/02_DOMAIN_MODEL.md).
model BmhpItem {
  id              String           @id @default(uuid())
  hospitalId      String           @map("hospital_id")
  code            String
  name            String
  unit            String
  standardCost    Decimal          @map("standard_cost") @db.Decimal(14, 2)
  vendorId        String?          @map("vendor_id")
  status          MasterDataStatus @default(active)
  /// See `Employee.sourceFileId` doc comment — same semantics.
  sourceFileId    String?          @map("source_file_id")
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  hospital   Hospital     @relation(fields: [hospitalId], references: [id])
  vendor     Vendor?      @relation(fields: [vendorId], references: [id])
  sourceFile UploadBatch? @relation(fields: [sourceFileId], references: [id])
  createdBy  User?        @relation("BmhpItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy  User?        @relation("BmhpItemUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@index([sourceFileId])
  @@map("bmhp_items")
}

/// Append-only tariff history (docs/02_DOMAIN_MODEL.md `tariffs` note) — a new
/// row is inserted on every tariff change rather than editing in place;
/// `Service.currentTariff` is the denormalized pointer to the active row.
model Tariff {
  id                 String       @id @default(uuid())
  hospitalId         String       @map("hospital_id")
  serviceId          String       @map("service_id")
  currentTariff      Decimal      @map("current_tariff") @db.Decimal(14, 2)
  recommendedTariff  Decimal?     @map("recommended_tariff") @db.Decimal(14, 2)
  effectiveDate      DateTime     @map("effective_date")
  approvedByUserId   String?      @map("approved_by_user_id")
  approvedAt         DateTime?    @map("approved_at")
  status             TariffStatus @default(active)
  /// See `Employee.sourceFileId` doc comment — same semantics, set for both
  /// direct Master Data creates going through an upload and bulk-uploaded rows.
  sourceFileId       String?      @map("source_file_id")
  /// The tariff this row superseded for the same service at creation time (if
  /// any) — set by both `TariffService.create()` and upload promotion, so a
  /// rollback can restore the exact prior active tariff + `Service.currentTariff`
  /// rather than guessing. Mirrors `AllocationRun.supersedesRunId`.
  supersedesTariffId String?      @unique @map("supersedes_tariff_id")
  createdByUserId    String?      @map("created_by_user_id")
  updatedByUserId    String?      @map("updated_by_user_id")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  deletedAt          DateTime?    @map("deleted_at")

  hospital         Hospital     @relation(fields: [hospitalId], references: [id])
  service          Service      @relation(fields: [serviceId], references: [id])
  sourceFile       UploadBatch? @relation(fields: [sourceFileId], references: [id])
  supersedesTariff Tariff?      @relation("TariffSupersedes", fields: [supersedesTariffId], references: [id])
  supersededBy     Tariff?      @relation("TariffSupersedes")
  approvedBy       User?        @relation("TariffApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  createdBy        User?        @relation("TariffCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy        User?        @relation("TariffUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([hospitalId])
  @@index([serviceId])
  @@index([sourceFileId])
  @@map("tariffs")
}

/// Configuration group (docs/02_DOMAIN_MODEL.md), one row per hospital.
/// Drives the allocation-method decision (`08_COST_ALLOCATION_ENGINE.md`) and
/// the default target margin used before any `target_margins` override
/// exists (deferred — needs `periods`, out of Sprint 3 scope). Defaults per
/// docs/24_CONFIGURATION.md §1 (`step_down`, 15%, January, `id-ID`, 25MB).
/// Only the Sprint-3/4-relevant settings from that table are modeled so
/// far — the rest (`ai_enabled`, `ai_monthly_token_budget`,
/// `email_notifications_enabled`) belong to AI/Notification sprints and are
/// added by whichever sprint owns that feature.
model HospitalSettings {
  id                      String           @id @default(uuid())
  hospitalId              String           @unique @map("hospital_id")
  allocationMethod        AllocationMethod @default(step_down) @map("allocation_method")
  defaultTargetMargin     Decimal          @default(15) @map("default_target_margin") @db.Decimal(5, 2)
  fiscalYearStartMonth    Int              @default(1) @map("fiscal_year_start_month")
  locale                  String           @default("id-ID")
  /// docs/06_UPLOAD_ENGINE.md §3, docs/24_CONFIGURATION.md — was deliberately
  /// left out of the Sprint-3 model (see this model's own doc comment
  /// above) since nothing consumed it yet; added now that upload intake
  /// (Sprint 4) needs a per-hospital limit to check against.
  maxUploadFileSizeMb     Int              @default(25) @map("max_upload_file_size_mb")
  /// docs/07_VALIDATION_ENGINE.md §3/§5: "rule thresholds (e.g., outlier
  /// stddev multiplier) are read from hospital_settings/config, not literals
  /// in code." `W_OUTLIER_NOMINAL` flags a value more than this many
  /// standard deviations from the trailing-6-period mean; 3 is the
  /// documented default heuristic.
  outlierStddevMultiplier Decimal          @default(3) @map("outlier_stddev_multiplier") @db.Decimal(4, 2)
  createdByUserId         String?          @map("created_by_user_id")
  updatedByUserId         String?          @map("updated_by_user_id")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  deletedAt               DateTime?        @map("deleted_at")

  hospital  Hospital @relation(fields: [hospitalId], references: [id])
  createdBy User?    @relation("HospitalSettingsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("HospitalSettingsUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("hospital_settings")
}

/// Fiscal period master (docs/02_DOMAIN_MODEL.md `periods`,
/// docs/25_PERIOD_CLOSING.md). Every transactional/calculation table and the
/// Upload Pipeline (Sprint 4) reference `period_id` rather than a free
/// string. `label` is the natural key within a hospital (e.g. "2026-06") and
/// doubles as the overlap guard for `generate()` (`@@unique`).
model Period {
  id              String       @id @default(uuid())
  hospitalId      String       @map("hospital_id")
  label           String
  startDate       DateTime     @map("start_date")
  endDate         DateTime     @map("end_date")
  status          PeriodStatus @default(draft)
  lockedAt        DateTime?    @map("locked_at")
  closedAt        DateTime?    @map("closed_at")
  reopenedAt      DateTime?    @map("reopened_at")
  createdByUserId String?      @map("created_by_user_id")
  updatedByUserId String?      @map("updated_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  hospital          Hospital          @relation(fields: [hospitalId], references: [id])
  createdBy         User?             @relation("PeriodCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy         User?             @relation("PeriodUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  uploadBatches     UploadBatch[]
  costEntries       CostEntry[]
  revenueEntries    RevenueEntry[]
  driverValues      DriverValue[]
  medicalActivities MedicalActivity[]
  allocationRuns    AllocationRun[]
  targetMargins     TargetMargin[]

  @@unique([hospitalId, label])
  @@index([hospitalId, status])
  @@map("periods")
}

/// docs/02_DOMAIN_MODEL.md `target_margins`, docs/01_BUSINESS_RULES.md §6.
/// `scope_id` is null exactly when `scope_type = hospital` (DB `CHECK`,
/// same polymorphic-shape convention as `driver_values`/`allocated_costs`).
enum TargetMarginScopeType {
  hospital
  profit_center
  service

  @@map("target_margin_scope_type")
}

/// Append-only history (Sprint 6 sub-task 0 design decision — carry-forward
/// resolution, mirroring `Tariff`'s active/superseded pattern rather than
/// `AllocationRule`'s exact-period-match): resolving the applicable target
/// margin for a given period picks the most recent row per scope level
/// whose `effectivePeriod.startDate <= ` the target period's, not an exact
/// `effective_period_id` match — so a margin set once keeps applying to
/// every later period until a newer row supersedes it, per
/// `01_BUSINESS_RULES.md` §6 ("takes effect from the next allocation run
/// onward"). No `update`/`status` column — a "change" is always a new row;
/// `set_by_user_id` + `created_at` are the audit trail
/// (`01_BUSINESS_RULES.md` §6: "every change is audit-logged").
model TargetMargin {
  id                String                @id @default(uuid())
  hospitalId        String                @map("hospital_id")
  scopeType         TargetMarginScopeType @map("scope_type")
  scopeId           String?               @map("scope_id")
  targetMargin      Decimal               @map("target_margin") @db.Decimal(5, 2)
  effectivePeriodId String                @map("effective_period_id")
  setByUserId       String                @map("set_by_user_id")
  createdAt         DateTime              @default(now()) @map("created_at")

  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  effectivePeriod Period   @relation(fields: [effectivePeriodId], references: [id])
  setBy           User     @relation("TargetMarginSetBy", fields: [setByUserId], references: [id])

  @@index([hospitalId, scopeType, scopeId])
  @@map("target_margins")
}

/// Upload Pipeline (docs/02_DOMAIN_MODEL.md §2 `upload_batches`,
/// docs/06_UPLOAD_ENGINE.md §2). All 8 documented types are modeled here
/// (the enum is cheap and matches the domain model exactly) even though
/// Sprint 4 sub-task 3 only accepts `cost`/`revenue` at the application
/// layer for now — see `upload.constants.ts`'s `SUPPORTED_UPLOAD_TYPES`.
enum UploadType {
  cost
  revenue
  driver
  asset
  employee
  medical_activity
  bmhp
  tariff

  @@map("upload_type")
}

enum UploadBatchStatus {
  staged
  validating
  validated
  confirmed
  rolled_back
  failed

  @@map("upload_batch_status")
}

/// Append-only — not a master-data/configuration table, so no soft-delete
/// (docs/02_DOMAIN_MODEL.md §3's soft-delete convention doesn't apply here);
/// corrections happen via rollback + a new batch, never in-place edits.
/// `fileUrl` stores the S3 object KEY (`StorageService.buildUploadKey()`),
/// not a URL — a signed download URL is generated on demand and expires, so
/// persisting one here would go stale.
model UploadBatch {
  id               String            @id @default(uuid())
  hospitalId       String            @map("hospital_id")
  type             UploadType
  periodId         String            @map("period_id")
  fileName         String            @map("file_name")
  fileUrl          String            @map("file_url")
  uploadedByUserId String            @map("uploaded_by_user_id")
  status           UploadBatchStatus @default(staged)
  rowCount         Int?              @map("row_count")
  errorCount       Int?              @map("error_count")
  createdAt        DateTime          @default(now()) @map("created_at")
  confirmedAt      DateTime?         @map("confirmed_at")
  rolledBackAt     DateTime?         @map("rolled_back_at")

  hospital          Hospital           @relation(fields: [hospitalId], references: [id])
  period            Period             @relation(fields: [periodId], references: [id])
  uploadedBy        User               @relation("UploadBatchUploadedBy", fields: [uploadedByUserId], references: [id])
  rows              UploadRowStaging[]
  validationErrors  ValidationError[]
  costEntries       CostEntry[]
  revenueEntries    RevenueEntry[]
  driverValues      DriverValue[]
  medicalActivities MedicalActivity[]
  assets            Asset[]
  employees         Employee[]
  bmhpItems         BmhpItem[]
  tariffs           Tariff[]

  @@index([hospitalId, status])
  @@index([periodId])
  @@map("upload_batches")
}

enum UploadRowStatus {
  valid
  invalid
  promoted

  @@map("upload_row_status")
}

/// docs/02_DOMAIN_MODEL.md `upload_rows_staging`. Holds parsed rows before
/// promotion to live tables — never queried by dashboards. No `hospital_id`
/// column of its own (matches the documented field list exactly); RLS scopes
/// via an `EXISTS` join to `upload_batches.hospital_id`, the same pattern
/// `role_permissions`/`refresh_tokens` already use in
/// `20260713120000_add_row_level_security` for child tables without their
/// own tenant column.
model UploadRowStaging {
  id            String          @id @default(uuid())
  uploadBatchId String          @map("upload_batch_id")
  rowNumber     Int             @map("row_number")
  rawJson       Json            @map("raw_json")
  status        UploadRowStatus @default(valid)
  createdAt     DateTime        @default(now()) @map("created_at")

  uploadBatch UploadBatch @relation(fields: [uploadBatchId], references: [id])

  @@index([uploadBatchId])
  @@map("upload_rows_staging")
}

enum ValidationSeverity {
  error
  warning

  @@map("validation_severity")
}

/// docs/02_DOMAIN_MODEL.md `validation_errors`, docs/07_VALIDATION_ENGINE.md
/// §2 error-code taxonomy. `rowNumber` is nullable — structural errors
/// (`E_TEMPLATE_VERSION`, `E_REQUIRED_COLUMN_MISSING`) are file-level, not
/// tied to a specific row; row-level/cross-row errors (Sprint 4 sub-task 5)
/// always set it. Same no-`hospital_id`/`EXISTS`-join RLS shape as
/// `UploadRowStaging` above.
model ValidationError {
  id            String             @id @default(uuid())
  uploadBatchId String             @map("upload_batch_id")
  rowNumber     Int?               @map("row_number")
  columnName    String?            @map("column_name")
  errorCode     String             @map("error_code")
  message       String
  severity      ValidationSeverity
  createdAt     DateTime           @default(now()) @map("created_at")

  uploadBatch UploadBatch @relation(fields: [uploadBatchId], references: [id])

  @@index([uploadBatchId])
  @@map("validation_errors")
}

// --- Transactional (docs/02_DOMAIN_MODEL.md §1, DATABASE_SCHEMA.md) --------

/// docs/02_DOMAIN_MODEL.md §4: "Transactional and calculation tables... are
/// append-only and not soft-deleted; corrections happen via new
/// upload_batches/allocation_runs, never in-place edits" — no `updatedAt`/
/// `deletedAt` here, matching that convention. `periodId`/`sourceFileId` are
/// real FKs (`Period`/`UploadBatch`), not the free-string/implicit-id
/// `DATABASE_SCHEMA.md` originally had — same normalization already applied
/// to `UploadBatch.periodId`. Written only by `ConfirmService.confirm()`
/// (Sprint 4 sub-task 6) inside its all-or-nothing promotion transaction;
/// removed only by `ConfirmService.rollback()`, scoped by `sourceFileId`
/// (docs/01_BUSINESS_RULES.md §5).
model CostEntry {
  id           String   @id @default(uuid())
  hospitalId   String   @map("hospital_id")
  periodId     String   @map("period_id")
  costCenterId String   @map("cost_center_id")
  coaAccountId String   @map("coa_account_id")
  nominal      Decimal  @db.Decimal(16, 2)
  sourceFileId String   @map("source_file_id")
  createdAt    DateTime @default(now()) @map("created_at")

  hospital   Hospital    @relation(fields: [hospitalId], references: [id])
  period     Period      @relation(fields: [periodId], references: [id])
  costCenter CostCenter  @relation(fields: [costCenterId], references: [id])
  coaAccount CoaAccount  @relation(fields: [coaAccountId], references: [id])
  sourceFile UploadBatch @relation(fields: [sourceFileId], references: [id])

  @@index([hospitalId, periodId])
  @@index([sourceFileId])
  @@map("cost_entries")
}

model RevenueEntry {
  id             String   @id @default(uuid())
  hospitalId     String   @map("hospital_id")
  periodId       String   @map("period_id")
  profitCenterId String   @map("profit_center_id")
  serviceId      String   @map("service_id")
  volume         Decimal  @db.Decimal(14, 2)
  revenue        Decimal  @db.Decimal(16, 2)
  sourceFileId   String   @map("source_file_id")
  createdAt      DateTime @default(now()) @map("created_at")

  hospital     Hospital     @relation(fields: [hospitalId], references: [id])
  period       Period       @relation(fields: [periodId], references: [id])
  profitCenter ProfitCenter @relation(fields: [profitCenterId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])
  sourceFile   UploadBatch  @relation(fields: [sourceFileId], references: [id])

  @@index([hospitalId, periodId])
  @@index([sourceFileId])
  @@map("revenue_entries")
}

/// A driver's value can target *either* a cost center (feeds step-down
/// cost-center-to-cost-center flow) or a profit center (feeds
/// cost-center-to-profit-center flow) — `DATABASE_SCHEMA.md`'s literal
/// `target_center_id` is a single generic column with no discriminator;
/// modeled here as two nullable FKs instead (Sprint 5 sub-task 0 design
/// decision) so the DB itself enforces the reference is valid, not just
/// application code. Exactly one of `targetCostCenterId` /
/// `targetProfitCenterId` is set per row — enforced by a `CHECK` constraint
/// added by hand in this model's migration (Prisma has no schema-level
/// syntax for it).
model DriverValue {
  id                   String   @id @default(uuid())
  hospitalId           String   @map("hospital_id")
  periodId             String   @map("period_id")
  driverId             String   @map("driver_id")
  targetCostCenterId   String?  @map("target_cost_center_id")
  targetProfitCenterId String?  @map("target_profit_center_id")
  value                Decimal  @db.Decimal(14, 2)
  sourceFileId         String   @map("source_file_id")
  createdAt            DateTime @default(now()) @map("created_at")

  hospital           Hospital      @relation(fields: [hospitalId], references: [id])
  period             Period        @relation(fields: [periodId], references: [id])
  driver             Driver        @relation(fields: [driverId], references: [id])
  targetCostCenter   CostCenter?   @relation(fields: [targetCostCenterId], references: [id])
  targetProfitCenter ProfitCenter? @relation(fields: [targetProfitCenterId], references: [id])
  sourceFile         UploadBatch   @relation(fields: [sourceFileId], references: [id])

  @@index([hospitalId, periodId])
  @@index([sourceFileId])
  @@map("driver_values")
}

/// Sprint 8 prerequisite — docs/02_DOMAIN_MODEL.md §1 groups this as
/// Transactional (same shape as RevenueEntry: period-scoped, append-only,
/// `sourceFileId` required not nullable), but unlike its siblings one row
/// here is one case/activity instance, not a period aggregate — many rows
/// legitimately share the same `(periodId, serviceId, doctorId)` tuple,
/// which is exactly what `docs/11_DOCTOR_ANALYTICS.md` §2's SUM/AVG-by-
/// doctor-and-service grouping requires. Feeds `service_direct_cost`
/// (`docs/10_UNIT_COST_ENGINE.md` §2) and `doctor_profitability_results`
/// (`docs/11_DOCTOR_ANALYTICS.md` §2). Written only by
/// `ConfirmService.confirm()`'s `medical_activity` branch; removed only by
/// `rollback()`, hard-deleted by `sourceFileId` — same semantics as
/// CostEntry/RevenueEntry/DriverValue, not the insert-only-with-soft-delete
/// pattern used for Asset/Employee/BmhpItem/Tariff uploads.
model MedicalActivity {
  id              String   @id @default(uuid())
  hospitalId      String   @map("hospital_id")
  periodId        String   @map("period_id")
  serviceId       String   @map("service_id")
  doctorId        String   @map("doctor_id")
  volume          Decimal  @db.Decimal(14, 2)
  durationMinutes Int      @map("duration_minutes")
  bmhpCost        Decimal  @map("bmhp_cost") @db.Decimal(16, 2)
  roomCost        Decimal  @map("room_cost") @db.Decimal(16, 2)
  staffCost       Decimal  @map("staff_cost") @db.Decimal(16, 2)
  revenue         Decimal  @db.Decimal(16, 2)
  sourceFileId    String   @map("source_file_id")
  createdAt       DateTime @default(now()) @map("created_at")

  hospital   Hospital    @relation(fields: [hospitalId], references: [id])
  period     Period      @relation(fields: [periodId], references: [id])
  service    Service     @relation(fields: [serviceId], references: [id])
  doctor     Doctor      @relation(fields: [doctorId], references: [id])
  sourceFile UploadBatch @relation(fields: [sourceFileId], references: [id])

  @@index([hospitalId, periodId])
  @@index([sourceFileId])
  // Hot path: queried by groupBy(serviceId) for the unit-cost engine AND
  // groupBy(doctorId, serviceId) for the doctor-profitability engine and
  // the comparison read API — neither sibling table needs this shape.
  @@index([serviceId, periodId])
  @@map("medical_activities")
}

// --- Calculation (docs/02_DOMAIN_MODEL.md §1, DATABASE_SCHEMA.md) ----------

/// `completed_with_errors` (Sprint 6 sub-task 1, docs/09_PROFITABILITY_ENGINE.md
/// §3): the allocation math itself succeeded and `allocated_costs` are valid
/// and preserved, but the chained `profitability.compute` stage failed — a
/// distinct terminal state from `failed` (allocation math itself failed, no
/// allocated_costs at all) and from `completed` (both stages succeeded).
enum AllocationRunStatus {
  draft
  running
  completed
  completed_with_errors
  failed

  @@map("allocation_run_status")
}

/// docs/08_COST_ALLOCATION_ENGINE.md §3 run lifecycle: draft -> running ->
/// completed | failed. Immutable once `completed`
/// (docs/01_BUSINESS_RULES.md §4) — recalculation always creates a NEW row
/// with `supersedesRunId` set, never mutates an existing completed run. No
/// `updatedAt`/soft-delete — same append-only convention as `CostEntry` et
/// al (Calculation group, not Master Data). `supersedesRunId` is `@unique`
/// so the supersede chain stays linear (only one run may claim to supersede
/// a given prior run).
model AllocationRun {
  id              String              @id @default(uuid())
  hospitalId      String              @map("hospital_id")
  periodId        String              @map("period_id")
  method          AllocationMethod
  status          AllocationRunStatus @default(draft)
  startedAt       DateTime?           @map("started_at")
  finishedAt      DateTime?           @map("finished_at")
  errorMessage    String?             @map("error_message")
  /// Run-level warnings that don't fail the run (currently only
  /// `W_DRIVER_ZERO` — docs/08_COST_ALLOCATION_ENGINE.md §5's
  /// no-driver-data case, confirmed Sprint 5 deviation: equal-split instead
  /// of leaving unallocated, but never silent). Array of
  /// `{ code, costCenterId, driverId }`, set once on completion — not
  /// appended to incrementally.
  warnings        Json?
  supersedesRunId String?             @unique @map("supersedes_run_id")
  /// docs/01_BUSINESS_RULES.md §5: an upload rollback invalidates every
  /// `allocation_run` for the affected period by marking it stale — never
  /// deleted or mutated otherwise (still viewable for audit), but the
  /// dashboard must fall back to the latest non-stale `completed` run.
  /// Orthogonal to `status`: a stale run is still `completed`, just flagged.
  isStale         Boolean             @default(false) @map("is_stale")
  staleAt         DateTime?           @map("stale_at")
  createdByUserId String              @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  hospital                   Hospital                    @relation(fields: [hospitalId], references: [id])
  period                     Period                      @relation(fields: [periodId], references: [id])
  createdBy                  User                        @relation("AllocationRunCreatedBy", fields: [createdByUserId], references: [id])
  supersedesRun              AllocationRun?              @relation("AllocationRunSupersedes", fields: [supersedesRunId], references: [id])
  supersededBy               AllocationRun?              @relation("AllocationRunSupersedes")
  allocatedCosts             AllocatedCost[]
  profitabilityResults       ProfitabilityResult[]
  serviceUnitCosts           ServiceUnitCost[]
  doctorProfitabilityResults DoctorProfitabilityResult[]

  @@index([hospitalId, periodId])
  @@map("allocation_runs")
}

/// Immutable once its run is `completed` — no update/delete path exists at
/// the application layer, matching `docs/01_BUSINESS_RULES.md` §4. Target
/// is polymorphic (docs/08_COST_ALLOCATION_ENGINE.md §2's step-down flow: a
/// cost center allocates to *either* another cost center or a profit
/// center) — same two-nullable-FK + `CHECK`-constraint design as
/// `DriverValue`. No `hospital_id` column of its own — matches
/// `DATABASE_SCHEMA.md`'s literal `allocated_costs` field list exactly
/// (Calculation group, not Transactional); RLS scopes via an `EXISTS` join
/// to `allocation_runs.hospital_id`, the same pattern already used for
/// `upload_rows_staging`/`validation_errors`.
model AllocatedCost {
  id                   String   @id @default(uuid())
  allocationRunId      String   @map("allocation_run_id")
  sourceCostCenterId   String   @map("source_cost_center_id")
  targetCostCenterId   String?  @map("target_cost_center_id")
  targetProfitCenterId String?  @map("target_profit_center_id")
  driverId             String   @map("driver_id")
  amount               Decimal  @db.Decimal(16, 2)
  createdAt            DateTime @default(now()) @map("created_at")

  allocationRun      AllocationRun @relation(fields: [allocationRunId], references: [id])
  sourceCostCenter   CostCenter    @relation("AllocatedCostSource", fields: [sourceCostCenterId], references: [id])
  targetCostCenter   CostCenter?   @relation("AllocatedCostTarget", fields: [targetCostCenterId], references: [id])
  targetProfitCenter ProfitCenter? @relation(fields: [targetProfitCenterId], references: [id])
  driver             Driver        @relation(fields: [driverId], references: [id])

  @@index([allocationRunId])
  @@map("allocated_costs")
}

/// docs/09_PROFITABILITY_ENGINE.md §2, matches DATABASE_SCHEMA.md's literal
/// `profitability_results` field list — profit-center grain only (no
/// `service_id`; see the Sprint 6 sub-task 0 planning note in
/// `10_UNIT_COST_ENGINE.md` §1 for why service-level unit cost lives in a
/// sibling table instead). One row per profit center per run, written once
/// by the `profitability.compute` job chained after `allocation_run`
/// reaches `completed` — never recomputed in place; a `completed_with_errors`
/// run may have zero or partial rows. No `hospital_id` of its own (EXISTS-join
/// RLS against `allocation_runs`, same shape as `allocated_costs`).
model ProfitabilityResult {
  id              String   @id @default(uuid())
  allocationRunId String   @map("allocation_run_id")
  profitCenterId  String   @map("profit_center_id")
  revenue         Decimal  @db.Decimal(16, 2)
  directCost      Decimal  @map("direct_cost") @db.Decimal(16, 2)
  allocatedCost   Decimal  @map("allocated_cost") @db.Decimal(16, 2)
  totalCost       Decimal  @map("total_cost") @db.Decimal(16, 2)
  grossProfit     Decimal  @map("gross_profit") @db.Decimal(16, 2)
  /// Percentage scale (37.3 means 37.3%), null when revenue = 0
  /// (docs/09_PROFITABILITY_ENGINE.md §2 guard).
  margin          Decimal? @db.Decimal(9, 4)
  createdAt       DateTime @default(now()) @map("created_at")

  allocationRun AllocationRun @relation(fields: [allocationRunId], references: [id])
  profitCenter  ProfitCenter  @relation(fields: [profitCenterId], references: [id])

  @@index([allocationRunId])
  @@map("profitability_results")
}

/// docs/10_UNIT_COST_ENGINE.md §1: not in DATABASE_SCHEMA.md's literal
/// tables (that doc explicitly leaves the profitability-vs-unit-cost table
/// split to engineering) — a sibling table, not extra columns on
/// `ProfitabilityResult`, since that table's grain is profit-center-only.
/// Written in the same `profitability.compute` job / same transaction as
/// `ProfitabilityResult` (Sprint 6 sub-task 2). `serviceDirectCost` (Sprint 8)
/// = SUM(medical_activities.bmhp_cost + room_cost + staff_cost) for that
/// service+period; `serviceVolume` prefers medical_activities' own volume
/// when present for that service, else falls back to revenue_entries.volume
/// (docs/10_UNIT_COST_ENGINE.md §2) — see `ProfitabilityEngineService.
/// computeServiceUnitCostRows()`. `currentTariff`/`targetMarginUsed` are point-in-time snapshots of the
/// inputs used, not live references — a later tariff or target-margin
/// change must not retroactively alter an already-computed run's figures.
model ServiceUnitCost {
  id                   String   @id @default(uuid())
  allocationRunId      String   @map("allocation_run_id")
  serviceId            String   @map("service_id")
  serviceAllocatedCost Decimal  @map("service_allocated_cost") @db.Decimal(16, 2)
  serviceDirectCost    Decimal  @map("service_direct_cost") @db.Decimal(16, 2)
  serviceVolume        Decimal  @map("service_volume") @db.Decimal(14, 2)
  /// Null when serviceVolume = 0 (docs/10_UNIT_COST_ENGINE.md §2 guard).
  unitCost             Decimal? @map("unit_cost") @db.Decimal(16, 4)
  currentTariff        Decimal? @map("current_tariff") @db.Decimal(14, 2)
  tariffGap            Decimal? @map("tariff_gap") @db.Decimal(14, 4)
  /// Percentage scale (15 means 15%), the resolved value actually used —
  /// see TargetMarginService's class doc comment for the unit convention.
  targetMarginUsed     Decimal  @map("target_margin_used") @db.Decimal(9, 4)
  recommendedTariff    Decimal? @map("recommended_tariff") @db.Decimal(16, 4)
  createdAt            DateTime @default(now()) @map("created_at")

  allocationRun AllocationRun @relation(fields: [allocationRunId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])

  @@index([allocationRunId])
  @@map("service_unit_costs")
}

/// Sprint 8 (docs/11_DOCTOR_ANALYTICS.md §2) — one row per (doctor, service)
/// per allocation run, written in the SAME transaction as
/// ProfitabilityResult/ServiceUnitCost (docs/09_PROFITABILITY_ENGINE.md §3:
/// "the next stage of the same pipeline"), because `cost` apportions
/// `ServiceUnitCost.serviceAllocatedCost` further down to the doctor by
/// that doctor's volume share of the service (same revenue-weighted-style
/// apportionment as docs/10_UNIT_COST_ENGINE.md §3, just one level deeper).
/// No `hospitalId` — same EXISTS-join RLS pattern as ServiceUnitCost/
/// ProfitabilityResult against their shared parent allocation_runs. A
/// doctor+service pair with fewer than 5 cases this period still gets a
/// row here (still useful for other reports); only the `/comparison` read
/// API excludes it from cohort/percentile math (docs §3's minimum sample
/// size).
model DoctorProfitabilityResult {
  id              String   @id @default(uuid())
  allocationRunId String   @map("allocation_run_id")
  doctorId        String   @map("doctor_id")
  serviceId       String   @map("service_id")
  revenue         Decimal  @db.Decimal(16, 2)
  cost            Decimal  @db.Decimal(16, 2)
  profit          Decimal  @db.Decimal(16, 2)
  /// Percentage scale, null when revenue = 0 — same guard as ProfitabilityResult.margin.
  margin          Decimal? @db.Decimal(9, 4)
  avgDuration     Decimal  @map("avg_duration") @db.Decimal(9, 2)
  avgBmhp         Decimal  @map("avg_bmhp") @db.Decimal(16, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  allocationRun AllocationRun @relation(fields: [allocationRunId], references: [id])
  doctor        Doctor        @relation(fields: [doctorId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])

  @@index([allocationRunId, serviceId])
  @@map("doctor_profitability_results")
}

// --- Platform / Audit (docs/23_AUDIT_TRAIL.md, docs/02_DOMAIN_MODEL.md §1) -

/// Append-only audit trail (docs/23_AUDIT_TRAIL.md §5 — no update/delete path
/// exists at the application layer). Written by the global `AuditInterceptor`
/// for every successful mutating (POST/PATCH/PUT/DELETE) request.
model AuditLog {
  id         String   @id @default(uuid())
  /// Denormalized from the acting request's resolved tenant context
  /// (`TenantGuard`, which runs before this row is written — see
  /// `AuditInterceptor`). Not in `02_DOMAIN_MODEL.md`'s literal field list,
  /// but required so `GET /audit-logs` can apply the same hospital-scoped
  /// tenant isolation every other endpoint does (`22_ACCEPTANCE_CRITERIA.md`
  /// §8); nullable because `@Public()` routes (login) have no resolved
  /// hospital context.
  hospitalId String?  @map("hospital_id")
  userId     String?  @map("user_id")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([hospitalId])
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
