# apps/api local environment. Copy to .env for local development.
# docs/29_DEPLOYMENT.md §1 (local environment), §6 (env-var-only configuration).

NODE_ENV=development
PORT=3001

# Matches docker-compose.yml's postgres service (host port 5433 — 5432 is
# often already taken by another local project's Postgres container).
# This is the schema-OWNER connection (used by `prisma migrate`/`db seed`) —
# owners bypass Postgres row-level security, which migrations/seed rely on.
DATABASE_URL="postgresql://hpp:hpp@localhost:5433/hpp_dev?schema=public"

# The running API server's connection — a non-owner role (`hpp_app`,
# created by prisma/migrations/20260713120000_add_row_level_security) that
# is actually subject to RLS policies (docs/03_MULTI_TENANT.md §2). Local/CI
# password matches the migration's dev default; rotate for any real
# deployment (docs/14_SECURITY.md §1).
APP_DATABASE_URL="postgresql://hpp_app:hpp_app@localhost:5433/hpp_dev?schema=public"

# Matches docker-compose.yml's redis service (host port 6380). Consumed by BullMQ from Sprint 4 onward.
REDIS_URL="redis://localhost:6380"

# RS256 access-token signing keypair (docs/05_AUTHENTICATION.md §1). Do not
# fill these in by hand — run `pnpm --filter @hpp/api generate:jwt-keys`
# after copying this file to .env; it generates a fresh local-dev keypair and
# writes it in place of these placeholders.
JWT_ACCESS_PRIVATE_KEY=""
JWT_ACCESS_PUBLIC_KEY=""

# Seeded initial System Admin login (apps/api/prisma/seed.ts). Change the
# password for any environment beyond local dev.
SEED_SUPER_ADMIN_EMAIL="superadmin@contoh.local"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!Dev"
